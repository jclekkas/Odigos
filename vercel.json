{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "installCommand": "npm ci",
  "framework": null,
  "nodeVersion": "20.x",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "includeFiles": "dist/public/**"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api" }
  ]
}
